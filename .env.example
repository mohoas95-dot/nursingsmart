# PostgreSQL used by Prisma authentication
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/nursingsmart?schema=public"

# Initial administrator created by `npm run db:seed`.
AUTH_ADMIN_NATIONAL_ID="0010000003"
AUTH_ADMIN_FIRST_NAME="مدیر"
AUTH_ADMIN_LAST_NAME="سامانه"
# Omit to use the mandated initial password 1234. Change it immediately after login.
AUTH_ADMIN_INITIAL_PASSWORD="1234"

# Session cookie configuration
AUTH_SESSION_HOURS="12"
